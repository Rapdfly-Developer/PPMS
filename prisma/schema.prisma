// PPMS - Personal Patient Management System
// Multi-tenant EMR & appointment platform for visiting ophthalmologists

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// Identity & tenancy
// ──────────────────────────────────────────────────────────────────────────

// Role: DOCTOR | HOSPITAL | REFRACTIONIST
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          String
  email         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  doctor        Doctor?
  hospitalStaff HospitalStaff?
  refractionist Refractionist?
  auditLogs     AuditLog[]
  notifications Notification[]
  loginHistory  UserLoginHistory[]
  exportOtps         ExportOtp[]
  passwordResetTokens PasswordResetToken[]
}

model Doctor {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  name                String
  shortCode           String?  @unique
  specialty           String   @default("")
  contact             String?
  credentials         String?
  email               String?
  experience          String?
  medicalRegNumber    String?
  qualifications      String?
  signatureUrl        String?
  createdAt           DateTime @default(now())

  hospitalLinks  DoctorHospitalLink[]
  refractionists Refractionist[]
  patients       Patient[]
  appointments   Appointment[]
  visits         Visit[]
  availabilities DoctorAvailability[]
  license        TenantLicense?
}

model Hospital {
  id             String   @id @default(cuid())
  name           String
  shortCode      String   @unique
  email          String?
  address        String?
  contact        String?
  logoUrl        String?
  retentionYears Int      @default(7)
  createdAt      DateTime @default(now())

  doctorLinks    DoctorHospitalLink[]
  staff          HospitalStaff[]
  refractionists Refractionist[]
  patients       Patient[]
  appointments   Appointment[]
  visits         Visit[]
  availabilities DoctorAvailability[]
  chipOptions    ChipOption[]
  integration    HospitalIntegration?
  integrationLogs IntegrationLog[]
}

// ──────────────────────────────────────────────────────────────────────────
// Hospital Integration Engine
// PPMS keeps a standard internal clinical data model; each hospital gets an
// adapter + mapping config so new hospitals are onboarded via configuration,
// not core-code changes.
// ──────────────────────────────────────────────────────────────────────────

// integrationType: FHIR | HL7 | REST | CSV
// authType: NONE | API_KEY | BEARER | BASIC | OAUTH2
model HospitalIntegration {
  id                  String   @id @default(cuid())
  hospitalId          String   @unique
  hospital            Hospital @relation(fields: [hospitalId], references: [id])
  integrationType     String   @default("REST")
  apiEndpoint         String?
  authType            String   @default("NONE")
  credentialsEncrypted String? // AES-256-GCM; API key / token / client secret
  oauthTokenUrl       String?  // OAUTH2 only
  fieldMappingJson    String?  // JSON: PPMS field -> hospital field overrides
  transformationRules String?  // JSON: value-level transforms (e.g. sex M/F -> 1/2)
  syncEnabled         Boolean  @default(false)
  maxRetries          Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  logs IntegrationLog[]
}

// status: PENDING | SUCCESS | FAILED
// recordType: VISIT | PATIENT
model IntegrationLog {
  id              String   @id @default(cuid())
  integrationId   String
  integration     HospitalIntegration @relation(fields: [integrationId], references: [id])
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  patientId       String?
  visitId         String?
  recordType      String   @default("VISIT")
  status          String   @default("PENDING")
  requestPayload  String?  // what the adapter produced (truncated)
  responsePayload String?  // hospital ack / error body (truncated)
  errorMessage    String?
  retryCount      Int      @default(0)
  triggeredBy     String?  // AUTO | MANUAL | RETRY
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hospitalId, status])
  @@index([visitId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// Licensing & subscriptions
// ──────────────────────────────────────────────────────────────────────────

// paymentStatus: NONE | PENDING | PAID | FAILED
// plan: MONTHLY | YEARLY
// The DOCTOR is the licensee — one license covers the doctor and every
// hospital they operate. (Renamed conceptually from per-hospital tenancy.)
model TenantLicense {
  id                   String    @id @default(cuid())
  doctorId             String    @unique
  doctor               Doctor    @relation(fields: [doctorId], references: [id])

  // 30-day free trial
  trialStartsAt        DateTime  @default(now())
  trialEndsAt          DateTime

  // Paid subscription (null until first payment)
  plan                 String?
  subscriptionStartsAt DateTime?
  subscriptionEndsAt   DateTime?

  // Razorpay
  paymentStatus        String    @default("NONE")
  razorpayOrderId      String?
  razorpayPaymentId    String?
  razorpaySignature    String?

  // License key activation (offline/manual key)
  licenseKey           String?
  machineId            String?   // browser-generated UUID stored in cookie
  deviceName           String?
  lastVerifiedAt       DateTime?

  // Reminder tracking (bitfield: 1=7day, 2=3day, 4=1day)
  remindersSent        Int       @default(0)

  // HMAC of core license fields — detects out-of-band tampering
  signature            String?

  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([trialEndsAt])
  @@index([subscriptionEndsAt])
}

// Keys minted by the product owner (CLI script or admin card). A key must
// exist here, unused and unrevoked, before activateLicenseKey accepts it.
model IssuedLicenseKey {
  id             String    @id @default(cuid())
  key            String    @unique
  note           String?   // customer name / order reference
  months         Int       @default(12)
  createdAt      DateTime  @default(now())
  usedAt         DateTime?
  usedByDoctorId String?
  revoked        Boolean   @default(false)

  @@index([usedAt])
}

// License activation audit trail shown on /license/activate
model LicenseEvent {
  id          String   @id @default(cuid())
  doctorId    String
  action      String   // TRIAL_STARTED | ACTIVATED | REACTIVATED | VERIFIED
  keyMasked   String?
  performedBy String?
  status      String   // SUCCESS | FAILED
  detail      String?
  createdAt   DateTime @default(now())

  @@index([doctorId, createdAt])
}

// Scoped login for a Hospital, linked to exactly one Doctor-Hospital relationship
model HospitalStaff {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  name       String
  mobile     String?
  createdAt  DateTime @default(now())
}

model DoctorHospitalLink {
  id         String   @id @default(cuid())
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  active     Boolean  @default(true)

  @@unique([doctorId, hospitalId])
}

model Refractionist {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  name       String
  mobile     String?
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  createdAt  DateTime @default(now())
}

// Recurring weekly availability slots, e.g. "Mondays 16:00-19:00 at Hospital A"
model DoctorAvailability {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
  weekday     Int      // 0=Sun … 6=Sat
  startTime   String   // "HH:MM" 24h
  endTime     String
  slotMins    Int      @default(15)
  maxPatients Int      @default(5)
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt   DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────────────────
// Patients & appointments
// ──────────────────────────────────────────────────────────────────────────

// Sex: MALE | FEMALE | OTHER
model Patient {
  id              String   @id @default(cuid())
  uhid            String?  @unique // Hospital-based ID: PPMS-{HOSPITALCODE}-NNNN (nullable for legacy)
  udid            String?  @unique // Doctor-based ID:   PPMS-{DOCTORCODE}-NNNN
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id])
  registeredAtId  String?
  registeredAt    Hospital? @relation(fields: [registeredAtId], references: [id])
  name            String
  age             Int
  sex             String
  mobile          String
  aadhaarEncrypted String  // encrypted at rest; masked in UI except for Doctor
  category        String   @default("GENERAL") // GENERAL | BPL | SUBSIDISED | ECHS | INSURANCE
  address         String?
  city            String?
  state           String?
  pincode         String?
  complaint       String?
  occupation      String?
  notes           String?
  photoUrl        String?
  aadhaarPhotoUrl String?  // uploaded Aadhaar card scan (blob storage file name)
  createdAt       DateTime @default(now())

  appointments    Appointment[]
  visits          Visit[]
  pastExternalVisits PastExternalVisit[]
}

// AppointmentStatus: REQUESTED | CONFIRMED | RESCHEDULED | COMPLETED | CANCELLED | NO_SHOW
model Appointment {
  id         String            @id @default(cuid())
  patientId  String
  patient    Patient           @relation(fields: [patientId], references: [id])
  doctorId   String?
  doctor     Doctor?           @relation(fields: [doctorId], references: [id])
  hospitalId String
  hospital   Hospital          @relation(fields: [hospitalId], references: [id])
  dateTime   DateTime
  visitType  String            @default("General OPD")
  status             String   @default("REQUESTED")
  consultationStatus String?  // FINALIZED | null
  completedAt        DateTime?
  completedBy        String?  // Doctor name
  isWalkIn           Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  arrivedAt          DateTime?   // set when status → CONFIRMED (patient reached the clinic)

  visit      Visit?

  @@index([doctorId, dateTime])
}

// ──────────────────────────────────────────────────────────────────────────
// Visit (parent record for one consultation encounter)
// ──────────────────────────────────────────────────────────────────────────

model Visit {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  hospitalId    String
  hospital      Hospital @relation(fields: [hospitalId], references: [id])
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  date          DateTime @default(now())
  status        String   @default("IN_PROGRESS") // IN_PROGRESS | CLOSED
  visitType     String   @default("General OPD")
  finalizedAt   DateTime?
  finalizedBy   String?  // Doctor name at time of finalization
  sentToPharmacy Boolean @default(false)
  followUpDate   DateTime?
  referralEnabled Boolean @default(false)
  referralNote   String?

  generalExam        GeneralExamination?
  medications        Medication[]
  visualAcuity       VisualAcuity?
  refraction         RefractiveCorrection?
  colourVisionCS     ColourVisionContrastSensitivity?
  iopReadings        IOPReading[]
  anteriorSegment    AnteriorSegment?
  posteriorSegment   PosteriorSegment?
  diplopiaChart      DiplopiaChart?
  hessChart          HessChart?
  retinoscopy        Retinoscopy?
  tearFilm           TearFilm?
  lacrimalSac        LacrimalSacSyringing?
  investigationOrders InvestigationOrder[]
  diagnoses          Diagnosis[]
  dispense           Dispense?
  admission          Admission?
  surgicalCounselling SurgicalCounselling?
}

// ──────────────────────────────────────────────────────────────────────────
// General Examination
// ──────────────────────────────────────────────────────────────────────────

model GeneralExamination {
  id                  String   @id @default(cuid())
  visitId             String   @unique
  visit               Visit    @relation(fields: [visitId], references: [id])
  bp                  String?
  pulse                String?
  temperature         String?
  weight              String?
  chiefComplaint      String?
  hpi                 String?
  provisionalDx       String?
  pastMedicalHistory  String? // JSON array of chip values, cumulative
  pmhOtherText        String?
  medications         String? // free text list
  allergies           String?
  nkda                Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// Plan - Prescription (dispensed/prescribed drugs for this visit, distinct
// from GeneralExamination.medications which records the patient's reported
// ongoing medications at intake)
// ──────────────────────────────────────────────────────────────────────────

model Medication {
  id           String   @id @default(cuid())
  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id])
  drugName     String
  dosage       String?
  frequency    String?
  duration     String?
  instructions String?
  createdAt    DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────────────────
// Past External Visits (OCR ingestion)
// ──────────────────────────────────────────────────────────────────────────

// VerificationStatus: PENDING_REVIEW | VERIFIED | REJECTED
model PastExternalVisit {
  id                 String              @id @default(cuid())
  patientId          String
  patient            Patient             @relation(fields: [patientId], references: [id])
  sourceDate         DateTime?
  sourceHospital     String?
  extractedDiagnosis String?
  extractedTreatment String?
  scanFileRef        String?
  verificationStatus String              @default("PENDING_REVIEW")
  createdAt          DateTime            @default(now())
}

// ──────────────────────────────────────────────────────────────────────────
// Ophthalmic Examination sub-modules (RE/LE captured as JSON per eye)
// ──────────────────────────────────────────────────────────────────────────

model VisualAcuity {
  id               String   @id @default(cuid())
  visitId          String   @unique
  visit            Visit    @relation(fields: [visitId], references: [id])
  testMethod       String?  // Snellen | E-chart | LogMAR | Symbols | HOTV
  re               String?  // JSON: { distanceUnaided, distancePinhole, distanceBestCorrected, nearUnaided, nearPinhole, nearBestCorrected }
  le               String?
  reviewedByDoctor Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model RefractiveCorrection {
  id               String   @id @default(cuid())
  visitId          String   @unique
  visit            Visit    @relation(fields: [visitId], references: [id])
  re               String?  // JSON: { distance: {sph,cyl,axis,va}, near: {sph,cyl,axis,va} }
  le               String?
  sentToOpticals   Boolean  @default(false)
  reviewedByDoctor Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model ColourVisionContrastSensitivity {
  id               String   @id @default(cuid())
  visitId          String   @unique
  visit            Visit    @relation(fields: [visitId], references: [id])
  re               String?  // JSON: { ishihara, d15, lanthonyD15, hrr, cityUniv, pelliRobson, marsLetterCS, vistech, fact }
  le               String?
  reviewedByDoctor Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model IOPReading {
  id               String   @id @default(cuid())
  visitId          String
  visit            Visit    @relation(fields: [visitId], references: [id])
  re               Float?
  le               Float?
  method           String?  // NCT | Goldmann | ...
  takenAt          DateTime @default(now())
  source           String   @default("DOCTOR") // DOCTOR | REFRACTIONIST
  reviewedByDoctor Boolean  @default(false)
}

model AnteriorSegment {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  re        String?  // JSON: { upperLid, lowerLid, conjunctiva, sclera, cornea, anteriorChamber, iris, pupil, lens, freeText }
  le        String?
  updatedAt DateTime @updatedAt
}

model PosteriorSegment {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  re        String?  // JSON: { media, discSize, discShape, discColour, discVessels, cdr, nrr, macula, retinalVessels, periphery }
  le        String?
  notes     String?
  updatedAt DateTime @updatedAt
}

model DiplopiaChart {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  grid      String   // JSON map of 9 positions -> { status: NOT_TESTED|NO_DIPLOPIA|DIPLOPIA_PRESENT, notes }
  updatedAt DateTime @updatedAt
}

model HessChart {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  grid      String   // JSON map of 9 positions -> { reH, reV, leH, leV }
  interpretation String?
  updatedAt DateTime @updatedAt
}

model Retinoscopy {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  re        String?
  le        String?
  updatedAt DateTime @updatedAt
}

model TearFilm {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  tbutRe    Float?
  tbutLe    Float?
  schirmer1Re Float?
  schirmer1Le Float?
  schirmer2Re Float?
  schirmer2Le Float?
  updatedAt DateTime @updatedAt
}

model LacrimalSacSyringing {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  re        String?  // JSON chips + free text
  le        String?
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// Investigations & Assessment
// ──────────────────────────────────────────────────────────────────────────

// OrderPriority: ROUTINE | URGENT | STAT
// OrderStatus: ORDERED | IN_PROGRESS | RESULT_AVAILABLE | REVIEWED
model InvestigationOrder {
  id         String        @id @default(cuid())
  visitId    String
  visit      Visit         @relation(fields: [visitId], references: [id])
  category   String        // Imaging & Functional Tests | Pre-op & Lab
  testName   String
  priority   String        @default("ROUTINE")
  laterality String?       // RE | LE | OU
  notes      String?
  status     String        @default("ORDERED")
  resultRef  String?
  createdAt  DateTime      @default(now())
}

// DiagnosisStatus: ACTIVE | RESOLVED | CHRONIC
model Diagnosis {
  id          String          @id @default(cuid())
  visitId     String
  visit       Visit           @relation(fields: [visitId], references: [id])
  icd10Code   String
  description String
  status      String          @default("ACTIVE")
  laterality  String?         // RE | LE | OU
  provisional Boolean         @default(false)
  createdAt   DateTime        @default(now())
}

// ──────────────────────────────────────────────────────────────────────────
// Disposition
// ──────────────────────────────────────────────────────────────────────────

model Dispense {
  id           String   @id @default(cuid())
  visitId      String   @unique
  visit        Visit    @relation(fields: [visitId], references: [id])
  shortSummary String
  longSummaryUrl String?
  createdAt    DateTime @default(now())
}

model Admission {
  id              String    @id @default(cuid())
  visitId         String    @unique
  visit           Visit     @relation(fields: [visitId], references: [id])
  reason          String
  ward            String
  numberOfDays    Int
  discharged      Boolean   @default(false)
  dischargedAt    DateTime?
  createdAt       DateTime  @default(now())
}

model SurgicalCounselling {
  id              String   @id @default(cuid())
  visitId         String   @unique
  visit           Visit    @relation(fields: [visitId], references: [id])
  surgeryType     String
  rightEye        Boolean  @default(false)
  leftEye         Boolean  @default(false)
  anaesthesiaType String
  surgeryDate     DateTime
  conflictFlag    Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────────────────
// Audit trail
// ──────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────
// In-app notifications
// ──────────────────────────────────────────────────────────────────────────

// NotificationType: APPOINTMENT_REQUESTED | APPOINTMENT_CONFIRMED | APPOINTMENT_RESCHEDULED
//                   APPOINTMENT_CANCELLED | PATIENT_ADMITTED | GENERAL
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  entityId  String?  // optional reference (appointmentId, visitId, etc.)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  oldValue   String?
  newValue   String?
  timestamp  DateTime @default(now())

  // Extended fields for richer audit context
  hospitalId String?
  moduleName String?
  actionType String?   // CREATE | UPDATE | DELETE | VIEW | PRINT | DOWNLOAD
  ipAddress  String?
  userName   String?

  @@index([userId, timestamp])
  @@index([hospitalId, timestamp])
}

// ──────────────────────────────────────────────────────────────────────────
// Login & session tracking
// ──────────────────────────────────────────────────────────────────────────

model UserLoginHistory {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  userName     String
  role         String
  hospitalId   String?
  hospitalName String?
  loginAt      DateTime  @default(now())
  logoutAt     DateTime?
  ipAddress    String?
  userAgent    String?
  status       String    @default("SUCCESS")  // SUCCESS | FAILED
  isActive     Boolean   @default(true)
  failReason   String?

  @@index([userId, loginAt])
  @@index([status, loginAt])
  @@index([isActive])
}

// ──────────────────────────────────────────────────────────────────────────
// Email Verification OTP — for trial registration email confirmation
// ──────────────────────────────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ──────────────────────────────────────────────────────────────────────────
// Export OTP — short-lived codes for authorising data downloads
// ──────────────────────────────────────────────────────────────────────────

model ExportOtp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

// Short-lived OTP record for mobile-number login
model MobileOtp {
  id         String    @id @default(cuid())
  mobile     String
  otpHash    String
  loginToken String?   @unique  // set after OTP verified; used to complete sign-in
  tokenExpAt DateTime?           // 5 min window to exchange token → session
  expiresAt  DateTime
  used       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([mobile, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  email      String
  otpHash    String
  resetToken String?   @unique  // populated after OTP verified; used in final step
  expiresAt  DateTime            // OTP expires 5 min after creation
  tokenExpAt DateTime?           // resetToken expires 10 min after OTP verify
  usedAt     DateTime?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
  @@index([resetToken])
}

// ──────────────────────────────────────────────────────────────────────────
// RBAC — granular permissions per role
// ──────────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique   // matches User.role string e.g. "HOSPITAL"
  label       String             // "Hospital Admin"
  description String?
  isSystem    Boolean  @default(false)   // DOCTOR/HOSPITAL/REFRACTIONIST locked
  isActive    Boolean  @default(true)
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique  // e.g. "patients.view", "emr.edit"
  label String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         String     // "DOCTOR" | "HOSPITAL" | "REFRACTIONIST"
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

// Configurable chip/dropdown values per hospital (or global when hospitalId is null)
// category examples: "PMH", "VISIT_TYPE", "INVESTIGATION_TYPE"
model ChipOption {
  id         String    @id @default(cuid())
  category   String
  value      String
  label      String
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])
  sortOrder  Int       @default(0)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@unique([category, value, hospitalId])
  @@index([category, hospitalId])
}
